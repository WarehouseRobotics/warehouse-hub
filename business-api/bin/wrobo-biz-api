#!/usr/bin/env python3
"""wrobo-biz-api: Remote HTTP CLI wrapper for the Warehouse Hub Business API.

Thin entry point that bootstraps ``sys.path`` so the sibling
``wrobo_biz_api/`` package is importable when this file is executed
directly from ``business-api/bin/`` regardless of the caller's cwd.

All command logic lives in the package; this shim only forwards argv.
"""

from __future__ import annotations

import os
import sys


def _bootstrap() -> None:
    here = os.path.dirname(os.path.realpath(__file__))
    if here not in sys.path:
        sys.path.insert(0, here)


_bootstrap()

from wrobo_biz_api import main  # noqa: E402  (import after sys.path fix-up)


if __name__ == "__main__":
    sys.exit(main())
