{
  "name": "@warehouse-hub/business-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Warehouse Hub Business API server and CLI scaffold",
  "bin": {
    "wrobo-biz": "./bin/wrobo-biz"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/src/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "db:init": "tsx src/cli.ts db init",
    "db:migrate": "tsx src/cli.ts db migrate",
    "cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "bullmq": "^5.73.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "express": "^4.21.2",
    "file-type": "^22.0.0",
    "jose": "^6.2.2",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.1.5",
    "node-llama-cpp": "^3.17.1",
    "sqlite-vec": "^0.1.9",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.14",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.23.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
