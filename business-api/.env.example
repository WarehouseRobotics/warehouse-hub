PORT=3100
DATABASE_PATH=./data/business-api.sqlite
UPLOAD_DIR=./data/uploads
TMP_DIR=./data/tmp
API_KEY=test-api-key
LOG_LEVEL=info

WORKSPACE_NAME=Default Workspace
WORKSPACE_SLUG=default
BOOTSTRAP_OWNER_EMAIL=owner@example.com
BOOTSTRAP_OWNER_PASSWORD=change-me
DASHBOARD_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
HUB_AUTH_MODE=api-key
HUB_PASSWORD_LOGIN=1
AUTH_PASSWORD_LOGIN_ENABLED=true
AUTH_MAGIC_LINK_ENABLED=true
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_IP_LIMIT=30
AUTH_LOGIN_EMAIL_LIMIT=5
AUTH_MAGIC_LINK_REQUEST_IP_LIMIT=30
AUTH_MAGIC_LINK_REQUEST_EMAIL_LIMIT=5
AUTH_MAGIC_LINK_CONSUME_IP_LIMIT=60
AUTH_MAGIC_LINK_CONSUME_TOKEN_LIMIT=5
SESSION_TTL_DAYS=14
SESSION_MAX_LIFETIME_DAYS=30

HUB_ACCOUNTING_AGENT=accounting

OPENCLAW_AUTH_TOKEN=your-openclaw-api-token

# For sending automatic emails
RESEND_API_KEY=resend-api-key
