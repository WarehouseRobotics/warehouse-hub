# OpenClaw Gateway environment variables

# Warehouse Robotics Hub
WROBO_BUSINESS_API_CONTAINER_ENABLED=1
HUB_DIR=/home/user/.openclaw/workspace-hub-dev/warehouse-hub
HUB_DATA_DIR=/home/user/.openclaw/workspace-hub-dev/warehouse-hub/business-api/data
HUB_TMP_DIR=/home/user/.openclaw/workspace-hub-dev/warehouse-hub/business-api/data/tmp
HUB_URL=http://localhost:3300
HUB_ACCOUNTING_AGENT=accounting

# Debug tracing
# OPENCLAW_LLM_TRACE_URL=http://127.0.0.1:9797/log

# Enables launching GUI apps in the desktop shell
DISPLAY=:0
WAYLAND_DISPLAY=wayland-0
